# Database
DATABASE_URL="postgresql://user:password@localhost:5432/web3_payment"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Master Wallet (HD Wallet Seed - generate with ethers.js HDNodeWallet.createRandom().mnemonic.phrase)
MASTER_WALLET_MNEMONIC="your twelve word mnemonic phrase here for the master wallet"

# Deposit Wallet Derivation Path (m/44'/60'/0'/0/{index})
DEPOSIT_WALLET_PATH="m/44'/60'/0'/0"

# Ethereum RPC (Infura, Alchemy, etc.)
ETH_RPC_URL="https://mainnet.infura.io/v3/YOUR_INFURA_KEY"

# For testnet (Sepolia)
# ETH_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"

# WalletConnect Project ID (from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin wallet address (comma-separated for multiple admins)
ADMIN_WALLET_ADDRESSES="0xYourAdminWalletAddress"

# Withdrawal fee (in ETH)
WITHDRAWAL_FEE="0.001"

# Minimum withdrawal amount (in ETH)
MIN_WITHDRAWAL="0.01"

# Block confirmations required for deposit
REQUIRED_CONFIRMATIONS="12"

# Network (ethereum, sepolia)
NEXT_PUBLIC_NETWORK="sepolia"
CHAIN_ID="11155111"
